# Strategy: restructure combinational logic, upsize cells,
#           or relax via multicycle path exception.

# Path 1: slack=-3.780ns  (CRITICAL)
#   From: alu_reg/Q  →  To: mem_stage/D
set_multicycle_path 2 -setup \
    -from [get_cells {alu_reg/Q}] \
    -to   [get_cells {mem_stage/D}]

# Path 2: slack=-0.420ns  (MAJOR)
#   From: decode_reg/Q  →  To: execute_stage/D
# Upsize critical cells — run optimise_registers
optimize_registers -path_group CLK \
    -effort high

# Path 6: slack=-0.322ns  (MAJOR)
#   From: regfile_reg/Q  →  To: alu_input_mux/D
# Upsize critical cells — run optimise_registers
optimize_registers -path_group CLK \
    -effort high

# ── Hold violation fixes ────────────────────────────────
# Strategy: insert delay buffers on short paths.

# Path 4: hold slack=-0.080ns
#   From: wb_reg/Q  →  To: forwarding_mux/D
