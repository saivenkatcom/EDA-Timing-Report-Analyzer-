#============================================================
# Auto-generated SDC — design: risc_v_core
# Generated by eda_timing_analyzer.py
# Date: 2026-03-27 12:58
#============================================================

# ── Primary clock constraint ──────────────────────────
create_clock -name CLK \
             -period 5.0 \
             -waveform {0 2.5} \
             [get_ports CLK]

# ── Clock uncertainty (skew + jitter) ─────────────────
set_clock_uncertainty -setup 0.1 [get_clocks CLK]
set_clock_uncertainty -hold  0.05 [get_clocks CLK]

# ── I/O delays (assumed 30% of clock period) ──────────
set_input_delay  -max 1.5 -clock CLK [all_inputs]
set_output_delay -max 1.5 -clock CLK [all_outputs]

# ── Multicycle path exceptions (critical setup paths) ──
# These paths have combinational logic too deep for 1 cycle.
# Relaxing to 2-cycle allows the logic to settle properly.
set_multicycle_path 2 -setup \
    -from [get_cells {alu_reg/Q}] \
    -to   [get_cells {mem_stage/D}]

# ── Hold time fixes (min delay constraints) ────────────
# Increasing min delay forces tool to insert buffers/delays.
set_min_delay 0.18 \
    -from [get_cells {wb_reg/Q}] \
    -to   [get_cells {forwarding_mux/D}]

# ── False paths (scan / test mode — example) ───────────
